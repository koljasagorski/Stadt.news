{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gelsenkirchen-news",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "triggers": {
    "crons": ["*/10 * * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "NEWS",
      "id": "PASTE_KV_NAMESPACE_ID"
    }
  ],
  "observability": {
    "enabled": true
  }
}
